---
import BaseLayout from '../layouts/BaseLayout.astro';

const errorParam = Astro.url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  invalid_credentials: 'Usuario o contraseña incorrectos.',
  user_inactive: 'El usuario está inactivo. Contacta al administrador.',
  validation_error: 'Los datos ingresados no son válidos.',
};

const errorMessage = errorParam ? errorMessages[errorParam] ?? 'Ocurrió un error.' : null;
---

<BaseLayout title="Iniciar sesión">
  <main class="min-h-screen flex items-center justify-center bg-background px-4 py-8">
    <div class="w-full max-w-md">
      <div class="bg-surface rounded-xl shadow-sm border border-border p-8">
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-primary/10 rounded-xl mb-4">
            <span class="text-3xl">🥤</span>
          </div>
          <h1 class="text-2xl font-bold text-text-main">Sistema de Bebidas</h1>
          <p class="text-text-secondary mt-1 text-sm">Ingresa tus credenciales para continuar</p>
        </div>

        {errorMessage && (
          <div class="mb-6 p-3 bg-error/10 border border-error/30 text-error rounded-lg text-sm flex items-start gap-2">
            <span class="text-lg leading-none">⚠️</span>
            <span>{errorMessage}</span>
          </div>
        )}

        <form method="POST" action="/api/auth/login" class="space-y-4">
          <div>
            <label for="username" class="block text-sm font-medium text-text-main mb-1.5">
              Usuario
            </label>
            <input
              type="text"
              id="username"
              name="username"
              required
              autocomplete="username"
              autofocus
              class="w-full px-3 py-2.5 bg-background border border-border rounded-lg text-text-main placeholder:text-text-secondary/60 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition"
              placeholder="admin"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-text-main mb-1.5">
              Contraseña
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full px-3 py-2.5 bg-background border border-border rounded-lg text-text-main placeholder:text-text-secondary/60 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition"
              placeholder="••••••••"
            />
          </div>

          <button
            type="submit"
            class="w-full py-2.5 bg-primary hover:bg-primary-dark text-surface font-semibold rounded-lg transition-colors shadow-sm"
          >
            Iniciar sesión
          </button>
        </form>

        <p class="text-center text-xs text-text-secondary mt-6">
          Acceso exclusivo para personal autorizado.
        </p>
      </div>

      <p class="text-center text-xs text-text-secondary mt-4">
        © {new Date().getFullYear()} — Sistema interno
      </p>
    </div>
  </main>
</BaseLayout>